Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"plot", " ", "the", " ", "DEM"}], " ", "*)"}], " ", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"tableau", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"xmin", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"i", "-", "1"}], ")"}], " ", "pasX"}]}], ",", 
           RowBox[{"ymin", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"ny", "-", "k", "+", "1"}], ")"}], " ", "pasX"}]}], ",", 
           RowBox[{"newdata", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", "i"}], "]"}], "]"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "nx"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "ny"}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fnc", "=", 
     RowBox[{"Interpolation", "[", "tableau", "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"XImin", ",", "XImax"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"YImin", ",", "YImax"}], "}"}]}], "}"}], "=", 
     RowBox[{"ReleaseHold", "@", 
      RowBox[{"Extract", "[", 
       RowBox[{"fnc", ",", "1", ",", "Hold"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zmin", "=", 
     RowBox[{"Min", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "tableau"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"zmax", "=", 
     RowBox[{"Max", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "tableau"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"vue", "=", 
    RowBox[{"ContourPlot", "[", 
     RowBox[{
      RowBox[{"fnc", "[", 
       RowBox[{"x", ",", "y"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"x", ",", "XImin", ",", "XImax"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"y", ",", "YImin", ",", "YImax"}], "}"}], ",", 
      RowBox[{"Contours", "\[Rule]", 
       RowBox[{"Range", "[", 
        RowBox[{"zmin", ",", "zmax", ",", "10"}], "]"}]}], ",", " ", 
      RowBox[{"AspectRatio", "\[Rule]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"YImax", "-", "ymin"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"XImax", "-", "xmin"}], ")"}]}]}]}], " ", 
     "]"}]}]}]}]], "Input",
