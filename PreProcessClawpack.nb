Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"statusGlobal", "=", 
   RowBox[{"status", "=", "0"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"ProgressIndicator", "[", 
  RowBox[{"Dynamic", "[", "statusGlobal", "]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"ProgressIndicator", "[", 
  RowBox[{"Dynamic", "[", "status", "]"}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"file", "=", 
   RowBox[{"{", "}"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"status", "=", " ", 
      RowBox[{"k", " ", "/", "ny"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Do", "[", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"ind", "=", 
         RowBox[{"i", "+", 
          RowBox[{"ny", 
           RowBox[{"(", 
            RowBox[{"k", "-", "1"}], ")"}]}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"pt", "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"xmin", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"i", "-", "1"}], ")"}], "pasX"}]}], ",", 
           RowBox[{"ymin", "+", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"ny", "-", "k", "+", "1"}], ")"}], " ", "pasY"}]}]}], 
          "}"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"val", "=", "0"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Do", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"statusGlobal", "=", 
            RowBox[{"j", "/", 
             RowBox[{"Length", "@", "data2"}]}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"poly", "=", 
            RowBox[{"data2", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"xpmin", "=", 
            RowBox[{"Min", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "&"}], "/@", "poly"}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"ypmin", "=", 
            RowBox[{"Min", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "&"}], "/@", "poly"}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"xpmax", "=", 
            RowBox[{"Max", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "&"}], "/@", "poly"}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"ypmax", "=", 
            RowBox[{"Max", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"#", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "&"}], "/@", "poly"}], 
             "]"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{"If", "[", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{
              RowBox[{"xpmin", "\[LessEqual]", " ", 
               RowBox[{"pt", "[", 
                RowBox[{"[", "1", "]"}], "]"}], "\[LessEqual]", " ", 
               "xpmax"}], " ", "&&", " ", 
              RowBox[{"ypmin", "\[LessEqual]", " ", 
               RowBox[{"pt", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "\[LessEqual]", " ", 
               "ypmax"}]}], ",", "\[IndentingNewLine]", " ", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"RegionMember", "[", 
                RowBox[{
                 RowBox[{"Polygon", "@", "poly"}], ",", "pt"}], "]"}], ",", 
               " ", 
               RowBox[{"val", "=", "ICDepth"}]}], " ", "]"}]}], 
            "\[IndentingNewLine]", "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"Length", "[", "data2", "]"}]}], "}"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"file", "=", 
