Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{" ", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "export", " ", "the", " ", "DEM", " ", "in", " ", "the", " ", "format", 
    " ", "desired", " ", "by", " ", "clawpack"}], " ", "*)"}], " ", 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"ndata2", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"newdata", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"ndata2", "//", "Dimensions"}], "\[IndentingNewLine]", " ", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"fileExport", "=", 
     RowBox[{"OpenWrite", "[", 
      RowBox[{"\"\<topo.asc\>\"", ",", 
       RowBox[{"FormatType", "\[Rule]", "OutputForm"}], ",", 
       RowBox[{"PageWidth", "\[Rule]", "Infinity"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Write", "[", 
     RowBox[{"fileExport", ",", "\"\<ncols        \>\"", ",", "nx"}], "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Write", "[", 
     RowBox[{"fileExport", ",", "\"\<nrows        \>\"", ",", "ny"}], "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Write", "[", 
     RowBox[{"fileExport", ",", "\"\<xllcorner    \>\"", ",", 
      RowBox[{"Ceiling", "[", "xmin", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Write", "[", 
     RowBox[{"fileExport", ",", "\"\<yllcorner    \>\"", ",", 
      RowBox[{"Ceiling", "[", "ymin", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Write", "[", 
     RowBox[{"fileExport", ",", "\"\<cellsize     \>\"", ",", "pasX"}], "]"}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Write", "[", 
     RowBox[{"fileExport", ",", "\"\<nodata_value \>\"", ",", "NoDataValue"}],
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Write", "[", 
       RowBox[{"fileExport", ",", 
        RowBox[{"ndata2", "[", 
         RowBox[{"[", "i", "]"}], "]"}]}], "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"{", 
       RowBox[{"i", ",", "  ", 
        RowBox[{"Length", "@", "ndata2"}]}], "}"}]}], "]"}], "//", "Timing"}],
    "\[IndentingNewLine]", 
   RowBox[{"Close", "[", "fileExport", "]"}]}]}]], "Input",
