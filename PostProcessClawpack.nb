        "\[IndentingNewLine]", 
        RowBox[{"igrid", "+=", "1"}], ";", "\[IndentingNewLine]", 
        RowBox[{"start", "+=", 
         RowBox[{
          RowBox[{"mx", " ", "my"}], "+", "8"}]}]}]}], "\[IndentingNewLine]", 
      " ", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"interEta2", "[", "index", "]"}], "=", 
      RowBox[{"Interpolation", "[", 
