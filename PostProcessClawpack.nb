Cell[CellGroupData[{

Cell["Reading a map", "Section",
 CellChangeTimes->{{3.7730607635587997`*^9, 3.7730607723868*^9}, {
  3.7734920213347*^9, 
  3.7734920252867002`*^9}},ExpressionUUID->"378004d2-10ce-499c-a9c0-\
e064d614c145"],

Cell[CellGroupData[{

Cell["Level One Reading", "Subsection",
 CellChangeTimes->{{3.7734920023032*^9, 
  3.7734920363252*^9}},ExpressionUUID->"463bec90-0336-433c-be3b-8edb6bb8bb81"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"index", "=", "50"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dataTimes", "=", 
   RowBox[{"ReadList", "[", 
    RowBox[{
     RowBox[{"listeT", "[", 
      RowBox[{"[", "index", "]"}], "]"}], ",", "\"\<Word\>\"", ",", 
     RowBox[{"RecordLists", "\[Rule]", "True"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"infoTimes", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"#", "[", 
        RowBox[{"[", "2", "]"}], "]"}], ",", 
       RowBox[{"DataTransformation", "[", 
        RowBox[{"#", "[", 
         RowBox[{"[", "1", "]"}], "]"}], " ", "]"}]}], "}"}], "&"}], "/@", 
    RowBox[{"Take", "[", 
     RowBox[{"dataTimes", ",", "3"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ttt", "=", 
   RowBox[{"infoTimes", "[", 
    RowBox[{"[", 
     RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{
    "\"\<\[FilledSquare] Computation made at time t = \>\"", ",", "ttt"}], 
    "]"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"ReadList", "[", 
    RowBox[{
     RowBox[{"listeQ", "[", 
      RowBox[{"[", "index", "]"}], "]"}], ",", "\"\<Word\>\"", ",", 
     RowBox[{"RecordLists", "\[Rule]", "True"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ngrid", "=", 
   RowBox[{"Count", "[", 
    RowBox[{"data", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<1\>\"", ",", "\"\<AMR_level\>\""}], "}"}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"ngrid2", "=", 
   RowBox[{"Count", "[", 
    RowBox[{"data", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<2\>\"", ",", "\"\<AMR_level\>\""}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ngrid3", "=", 
   RowBox[{"Count", "[", 
    RowBox[{"data", ",", 
     RowBox[{"{", 
      RowBox[{"\"\<3\>\"", ",", "\"\<AMR_level\>\""}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"index", "<", "10"}], ",", 
    RowBox[{"indexName", "=", 
     RowBox[{"\"\<0\>\"", "<>", 
      RowBox[{"ToString", "[", "index", "]"}]}]}], ",", 
    RowBox[{"indexName", "=", 
     RowBox[{"ToString", "[", "index", "]"}]}]}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nameFile", "=", 
   RowBox[{"\"\<fort.q00\>\"", "<>", "indexName"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nameFileTimes", "=", 
   RowBox[{"\"\<fort.t00\>\"", "<>", "indexName"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"data", "=", 
   RowBox[{"ReadList", "[", 
    RowBox[{
     RowBox[{"listeQ", "[", 
      RowBox[{"[", "index", "]"}], "]"}], ",", "\"\<Word\>\"", ",", 
     RowBox[{"RecordLists", "\[Rule]", "True"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"values", "=", 
   RowBox[{"Drop", "[", 
    RowBox[{"data", ",", "8"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"info", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"#", "[", 
         RowBox[{"[", "2", "]"}], "]"}], ",", 
        RowBox[{"DataTransformation", "[", 
         RowBox[{"#", "[", 
          RowBox[{"[", "1", "]"}], "]"}], " ", "]"}]}], "}"}], "&"}], "/@", 
     RowBox[{"Take", "[", 
      RowBox[{"data", ",", "8"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"ngrid", "\[Equal]", "1"}], ",", 
   RowBox[{
   "Print", "[", "\"\<\[FilledCircle] I have found only 1 grid.\>\"", "]"}], 
   ",", 
   RowBox[{"Print", "[", 
    RowBox[{
    "\"\<\[FilledCircle] There are \>\"", ",", "ngrid", ",", 
     "\"\< grids of level 1.\>\""}], "]"}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"If", "[", 
   RowBox[{
    RowBox[{"ngrid", "\[Equal]", "1"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Delta]x", "=", 
      RowBox[{"info", "[", 
       RowBox[{"[", 
        RowBox[{"7", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[Delta]y", "=", 
      RowBox[{"info", "[", 
       RowBox[{"[", 
        RowBox[{"8", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"mx", "=", 
      RowBox[{"info", "[", 
       RowBox[{"[", 
        RowBox[{"3", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"my", "=", 
      RowBox[{"info", "[", 
       RowBox[{"[", 
        RowBox[{"4", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"xll", "=", 
      RowBox[{"info", "[", 
       RowBox[{"[", 
        RowBox[{"5", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yll", "=", 
      RowBox[{"info", "[", 
       RowBox[{"[", 
        RowBox[{"6", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yup", "=", 
      RowBox[{"yll", "+", 
       RowBox[{"my", " ", "\[Delta]y"}]}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{"coin", " ", "gauche", " ", "haut"}], " ", "*)"}], 
     "\[IndentingNewLine]", 
     RowBox[{"col1", "=", 
      RowBox[{"ArrayReshape", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"DataTransformation", "@", 
           RowBox[{"values", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", "1"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"mx", " ", "my"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"my", ",", "mx"}], "}"}]}], "]"}]}], ";", 
     RowBox[{"(*", " ", 
      RowBox[{"my", " ", "lignes", " ", "de", " ", "mx", " ", "colonnes"}], 
      " ", "*)"}], "\[IndentingNewLine]", 
     RowBox[{"col2", "=", 
      RowBox[{"ArrayReshape", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"DataTransformation", "@", 
           RowBox[{"values", "[", 
            RowBox[{"[", 
             RowBox[{"k", ",", "2"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"k", ",", 
            RowBox[{"mx", " ", "my"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"my", ",", "mx"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"col3", "=", 
