            RowBox[{"my", ",", "mx"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"col4", "=", 
         RowBox[{"ArrayReshape", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"DataTransformation", "@", 
              RowBox[{"values", "[", 
