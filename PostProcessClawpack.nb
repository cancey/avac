           RowBox[{"{", 
            RowBox[{"my", ",", "mx"}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"PartH2", "[", "igrid", "]"}], "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"xll", "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"j", "-", 
                 RowBox[{"1", "/", "2"}]}], ")"}], "*", "\[Delta]x"}]}], " ", 
             ",", 
