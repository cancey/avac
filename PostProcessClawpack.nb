Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"If", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ngrid2", ">", "0"}], ",", 
    RowBox[{
     RowBox[{"Print", "[", 
      RowBox[{
      "\"\<Reading on... \>\"", ",", "ngrid2", ",", " ", "\"\< grids.\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"data2", "=", 
      RowBox[{"Drop", "[", 
       RowBox[{"data", ",", "start"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"igrid", "=", "1"}], ";", 
     RowBox[{"start", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"igrid", "<=", "ngrid2"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"info", "=", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"#", "[", 
              RowBox[{"[", "2", "]"}], "]"}], ",", 
             RowBox[{"DataTransformation", "[", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}], " ", "]"}]}], "}"}], "&"}], "/@", 
          RowBox[{"Take", "[", 
           RowBox[{"data2", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"start", "+", "1"}], ",", 
              RowBox[{"start", "+", "8"}]}], "}"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"infogrid", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"infolevel", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"mx", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"3", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"my", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"4", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"xll", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"5", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"yll", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"6", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Delta]x", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"7", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"\[Delta]y", "=", 
         RowBox[{"info", "[", 
          RowBox[{"[", 
           RowBox[{"8", ",", "2"}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<\[Rule] I am reading \>\"", ",", "igrid", ",", 
          "\"\< of size \>\"", ",", "my", ",", " ", 
          "\"\< lines \[Times] \>\"", ",", "mx", ",", " ", 
          "\"\< columns. ClawPack ref: \>\"", ",", " ", "infogrid", ",", " ", 
          "\"\< (AMR level \>\"", ",", "infolevel", ",", "\"\<)\>\""}], "]"}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"yup", "=", 
         RowBox[{"yll", "+", 
          RowBox[{"my", " ", "\[Delta]y"}]}]}], ";", 
        RowBox[{"(*", " ", 
         RowBox[{"coin", " ", "gauche", " ", "haut"}], " ", "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"values", "=", 
         RowBox[{"Take", "[", 
          RowBox[{"data2", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"start", "+", "9"}], ",", 
             RowBox[{"start", "+", "8", "+", 
              RowBox[{"mx", " ", "my"}]}]}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"col1", "=", 
         RowBox[{"ArrayReshape", "[", 
          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"DataTransformation", "@", 
              RowBox[{"values", "[", 
               RowBox[{"[", 
                RowBox[{"k", ",", "1"}], "]"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", 
               RowBox[{"mx", " ", "my"}]}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"my", ",", "mx"}], "}"}]}], "]"}]}], ";", 
        RowBox[{"(*", " ", 
         RowBox[{"my", " ", "lignes", " ", "de", " ", "mx", " ", "colonnes"}],
          " ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{"col2", "=", 
