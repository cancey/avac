             ",", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"col1", "[", 
                 RowBox[{"[", 
                  RowBox[{"i", ",", "j"}], "]"}], "]"}], ">", "\[Epsilon]"}], 
               ",", 
               RowBox[{
