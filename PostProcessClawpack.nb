       RowBox[{"StringSplit", "[", 
        RowBox[{
         RowBox[{"data", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", "\"\< \>\""}], 
        "]"}]}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"i", ",", "7", ",", "dim"}], "}"}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"pasX", "=", 
  RowBox[{
   RowBox[{"StringCases", "[", 
    RowBox[{
     RowBox[{"data", "[", 
      RowBox[{"[", 
       RowBox[{"5", ",", "1"}], "]"}], "]"}], ",", 
     RowBox[{
      RowBox[{"x", ":", "NumberString"}], "\[RuleDelayed]", 
      RowBox[{"ToExpression", "[", "x", "]"}]}]}], "]"}], "[", 
   RowBox[{"[", "1", "]"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pasY", "=", 
   RowBox[{
    RowBox[{"StringCases", "[", 
     RowBox[{
      RowBox[{"data", "[", 
       RowBox[{"[", 
        RowBox[{"5", ",", "1"}], "]"}], "]"}], ",", 
      RowBox[{
       RowBox[{"x", ":", "NumberString"}], "\[RuleDelayed]", 
       RowBox[{"ToExpression", "[", "x", "]"}]}]}], "]"}], "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tableauTopo", "=", 
   RowBox[{"Flatten", "[", 
    RowBox[{
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"xmin", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"i", "-", "1"}], ")"}], " ", "pasX"}]}], ",", 
         RowBox[{"ymin", "+", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"ny", "-", "k", "+", "1"}], ")"}], " ", "pasX"}]}], ",", 
         RowBox[{"newdata", "[", 
          RowBox[{"[", 
           RowBox[{"k", ",", "i"}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "nx"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "ny"}], "}"}]}], "]"}], ",", "1"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fnc", "=", 
   RowBox[{"Interpolation", "[", "tableauTopo", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"XTmin", ",", "XTmax"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"YTmin", ",", "YTmax"}], "}"}]}], "}"}], "=", 
   RowBox[{"ReleaseHold", "@", 
    RowBox[{"Extract", "[", 
     RowBox[{"fnc", ",", "1", ",", "Hold"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"zTopoMin", "=", 
   RowBox[{"Min", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "[", 
       RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "tableauTopo"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"zTopoMax", "=", 
   RowBox[{"Max", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"#", "[", 
       RowBox[{"[", "3", "]"}], "]"}], "&"}], "/@", "tableauTopo"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"vue", "=", 
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"fnc", "[", 
     RowBox[{"x", ",", "y"}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "XTmin", ",", "XTmax"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "YTmin", ",", "YTmax"}], "}"}], ",", 
    RowBox[{"Contours", "\[Rule]", 
     RowBox[{"Range", "[", 
      RowBox[{"zTopoMin", ",", "zTopoMax", ",", "10"}], "]"}]}], ",", " ", 
    RowBox[{"AspectRatio", "\[Rule]", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"YTmax", "-", "ymin"}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{"XTmax", "-", "xmin"}], ")"}]}]}]}], " ", 
   "]"}]}], "\[IndentingNewLine]", 
