                 RowBox[{"1", "/", "2"}]}], ")"}], "*", "\[Delta]x"}]}], " ", 
             ",", 
             RowBox[{"yll", "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"i", "-", 
                 RowBox[{"1", "/", "2"}]}], ")"}], "*", "\[Delta]y"}]}], " ", 
             " ", ",", 
             RowBox[{"col4", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "j"}], "]"}], "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "my"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"j", ",", "mx"}], "}"}]}], " ", "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<  Grid \>\"", ",", "igrid", ",", 
          "\"\< whose left lower point is located at: (\>\"", ",", "xll", 
          ",", "\"\<, \>\"", ",", "yll", ",", "\"\<)\>\""}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<  Grid \>\"", ",", "igrid", ",", "\"\< \[Dash] x range: [\>\"", 
          ",", "xll", " ", ",", "\"\<, \>\"", ",", 
          RowBox[{"xll", "+", 
           RowBox[{"mx", " ", "\[Delta]x"}]}], ",", 
          "\"\<] step \[Delta]x = \>\"", ",", "\[Delta]x"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<  Grid \>\"", ",", "igrid", ",", 
          "\"\< \[Dash] \!\(\*StyleBox[\"y\",FontSlant->\"Italic\"]\) range: \
[\>\"", ",", "yll", " ", ",", "\"\<, \>\"", ",", 
          RowBox[{"yll", "+", 
           RowBox[{"my", " ", "\[Delta]y"}]}], ",", 
          "\"\<] step \[Delta]y = \>\"", ",", "\[Delta]y"}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"dessinPartH2", "[", "igrid", "]"}], "=", 
         RowBox[{"ListDensityPlot", "[", " ", 
          RowBox[{
           RowBox[{"Flatten", "[", 
            RowBox[{
             RowBox[{"PartH2", "[", "igrid", "]"}], ",", "1"}], "]"}], ",", 
           RowBox[{"Frame", "\[Rule]", "True"}]}], " ", "]"}]}], ";", 
        "\[IndentingNewLine]", 
