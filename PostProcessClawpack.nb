          RowBox[{
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"DataTransformation", "@", 
              RowBox[{"values", "[", 
               RowBox[{"[", 
                RowBox[{"k", ",", "2"}], "]"}], "]"}]}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", 
               RowBox[{"mx", " ", "my"}]}], "}"}]}], "]"}], ",", 
